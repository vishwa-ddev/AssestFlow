# AssetFlow - Apache Configuration

# Disable directory listing
Options -Indexes

# Protect sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to config, includes, models, controllers
    RewriteRule ^(config|includes|models|controllers|database)/ - [F,L]
</IfModule>

# Protect .htaccess and other dotfiles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
